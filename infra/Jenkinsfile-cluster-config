pipeline {
    agent any 
    parameters{
        string(name: 'VM_IP', description: 'Public IP adress of the VM to SSH', defaultValue: '13.91.94.19')
        string(name: 'GIT_REPO_URL', description: 'URL of the git repository', defaultValue: 'https://github.com/madhurgupta004/Jenkins-Practice.git')
        string(name: 'GIT_REPO_NAME', description: 'Name of the git repository', defaultValue: 'Jenkins-Practice')
        string(name: 'PATH_TO_K8_RESOURCES', description: 'Path to the k8 resources', defaultValue: 'resources/k8s-resources')
        string(name: 'CLUSTER_RG_NAME', description: 'Resource Group of cluster', defaultValue: 'azure-for-students-westus-dev-aks-rg')
        string(name: 'CLUSTER_NAME', description: 'Name of the cluster', defaultValue: 'azure-for-students-westus-dev-aks')
        string(name: 'PUBLIC_IP_NAME', description: 'Name of the public IP for public ingress', defaultValue: '816c1443-1915-49ee-9e22-f5bedccdbb17')
        string(name: 'CLUSTER_RESOURCES_RG_NAME', description: 'Resource Group of cluster resources', defaultValue: 'MC_azure-for-students-westus-dev-aks-rg_azure-for-students-westus-dev-aks_westus')
    }

    stages {
        stage('SSH into VM and deploy resources') {
            steps {
                script {
                    withCredentials([sshUserPrivateKey(credentialsId: 'SSH_CREDENTIALS', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USER'), 
                    usernamePassword(credentialsId: 'CLUSTER_ADMIN_USER', passwordVariable: 'ADMIN_PASSWORD', usernameVariable: 'ADMIN_USERNAME')]) {
                            sh """
                            ssh -o StrictHostKeyChecking=no -i ${SSH_KEY_FILE} ${SSH_USER}@${params.VM_IP}  '''
                            az login -u ${ADMIN_USERNAME} -p ${ADMIN_PASSWORD} ; 
                            az aks get-credentials --resource-group ${CLUSTER_RG_NAME} --name ${CLUSTER_NAME} --overwrite-existing ;
                            kubelogin convert-kubeconfig -l azurecli ;
                            az extension add --name aks-preview ;
                            az extension update --name aks-preview ;
                            az aks approuting enable --resource-group ${CLUSTER_RG_NAME} --name ${CLUSTER_NAME} --nginx None ;
                            kubectl get nginxIngressControllers ;
                            rm -rf ${params.GIT_REPO_NAME} ;
                            git clone ${params.GIT_REPO_URL} ;
                            cd ${params.GIT_REPO_NAME}
                            cd ${params.PATH_TO_K8_RESOURCES} ;
                            kubectl create namespace public-resources ;
                            kubectl create namespace private-resources ;
                            export IP=${PUBLIC_IP_NAME} ;
                            export RG=${CLUSTER_RESOURCES_RG_NAME} ;
                            envsubst < nginx-public-controller.yaml | kubectl apply -f -
                            kubectl apply -f nginx-internal-controller.yaml -f private-ingress-resource.yaml -f public-ingress-resource.yaml -f resources-private.yaml -f resources-public.yaml ;
                            kubectl get all -A ;
                            cd ../../../ ;
                            rm -rf ${params.GIT_REPO_NAME} ;
                            '''
                            """
                        }
                }
            }
        }
    }
}