pipeline {
    agent any 
    parameters{
        string(name: 'VM_IP', description: 'Public IP adress of the VM', defaultValue: '48.217.64.184')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/madhurgupta004/Jenkins-Practice.git'
            }
        }
        stage('SSH into VM') {
            steps {
                script {
                    withCredentials([sshUserPrivateKey(credentialsId: 'SSH_CREDENTIALS', keyFileVariable: 'SSH_KEY_FILE', usernameVariable: 'SSH_USER')]) {
                            sh '''
                            ssh -i $SSH_KEY_FILE $SSH_USER@$VM_IP"mkdir demo"
                            '''
                        }
                }
            }
        }
    }
}